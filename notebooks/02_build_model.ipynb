    "## Cell 9 — Full Unified Model\n",
    "\n",
    "Combines all streams into a single model that handles both images and videos.\n",
    "- Image path: 5 streams → cross-attention fusion → classification head\n",
    "- Video path: 5 streams per frame → temporal transformer → cross-attention fusion → classification head"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import torch\n",
    "import torch.nn as nn\n",
    "\n",
    "\n",
    "# Manipulation types for auxiliary classification task\n",
    "MANIPULATION_TYPES = [\n",
    "    'real',\n",
    "    'face_swap',\n",
    "    'face_reenactment',\n",
    "    'gan_generated',\n",
    "    'diffusion_generated',\n",
    "]\n",
    "N_TYPES = len(MANIPULATION_TYPES)\n",
    "\n",
    "\n",
    "class DeepTruthHybridV2(nn.Module):\n",
    "    \"\"\"\n",
    "    DeepTruth Hybrid v2 — Unified image + video deepfake detector.\n",
    "\n",
    "    Image input:  (B, 3, 224, 224)\n",
    "    Video input:  (B, T, 3, 224, 224)  where T = number of frames\n",
    "\n",
    "    Outputs:\n",
    "        fake_logit:  (B, 1)  — main binary classification\n",
    "        type_logits: (B, N_TYPES)  — manipulation type (auxiliary)\n",
    "        stream_feats: dict  — per-stream features for explainability\n",
    "    \"\"\"\n",
    "    def __init__(\n",
    "        self,\n",
    "        n_frames=32,\n",
    "        n_types=N_TYPES,\n",
    "        clip_freeze_layers=8,\n",
    "        dropout=0.4,\n",
    "    ):\n",
    "        super().__init__()\n",
    "\n",
    "        # ── Penta-Stream Backbone ──────────────────────────────\n",
    "        self.stream1_clip   = CLIPStream(freeze_layers=clip_freeze_layers, out_dim=512)\n",
    "        self.stream2_effnet = EfficientNetStream(out_dim=512)\n",
    "        self.stream3_freq   = FrequencyStream(out_dim=256)\n",
    "        self.stream4_srm    = SRMStream(out_dim=128)\n",
    "        self.stream5_gram   = GramStyleStream(out_dim=128)\n",
    "\n",
    "        stream_dims = [512, 512, 256, 128, 128]  # total = 1536\n",
    "        self.image_fusion = CrossAttentionFusion(stream_dims)\n",
    "\n",
    "        # After fusion: 5 streams × 256 (attn_dim) = 1280\n",
    "        fused_dim = 5 * 256\n",
    "\n",
    "        # ── Temporal Stream (video only) ──────────────────────\n",
    "        # Takes CLIP features from each frame as input\n",
    "        self.temporal = TemporalTransformer(in_dim=512, n_frames=n_frames, out_dim=512)\n",
    "        # For video: fused image features + temporal features\n",
    "        video_fused_dim = fused_dim + 512\n",
    "\n",
    "        # ── Image Classification Head ─────────────────────────\n",
    "        self.image_head = nn.Sequential(\n",
    "            nn.Linear(fused_dim, 512),\n",
    "            nn.BatchNorm1d(512),\n",
    "            nn.GELU(),\n",
    "            nn.Dropout(dropout),\n",
    "            nn.Linear(512, 256),\n",
    "            nn.BatchNorm1d(256),\n",
    "            nn.GELU(),\n",
    "            nn.Dropout(dropout * 0.75),\n",
    "        )\n",
    "        self.image_binary_out = nn.Linear(256, 1)\n",
    "        self.image_type_out   = nn.Linear(256, n_types)\n",
    "\n",
    "        # ── Video Classification Head ─────────────────────────\n",
    "        self.video_head = nn.Sequential(\n",
    "            nn.Linear(video_fused_dim, 512),\n",
    "            nn.BatchNorm1d(512),\n",
    "            nn.GELU(),\n",
    "            nn.Dropout(dropout),\n",
    "            nn.Linear(512, 256),\n",
    "            nn.BatchNorm1d(256),\n",
    "            nn.GELU(),\n",
    "            nn.Dropout(dropout * 0.75),\n",
    "        )\n",
    "        self.video_binary_out = nn.Linear(256, 1)\n",
    "        self.video_type_out   = nn.Linear(256, n_types)\n",
    "\n",
    "    def extract_image_features(self, x):\n",
    "        \"\"\"\n",
    "        Run penta-stream on a single image (or a batch of images).\n",
    "        x: (B, 3, 224, 224)\n",
    "        Returns: fused (B, 1280), stream_feats dict\n",
    "        \"\"\"\n",
    "        s1 = self.stream1_clip(x)\n",
    "        s2 = self.stream2_effnet(x)\n",
    "        s3 = self.stream3_freq(x)\n",
    "        s4 = self.stream4_srm(x)\n",
    "        s5 = self.stream5_gram(x)\n",
    "\n",
    "        fused, attn_weights = self.image_fusion([s1, s2, s3, s4, s5])\n",
    "\n",
    "        stream_feats = {\n",
    "            'clip':       s1,\n",
    "            'efficientnet': s2,\n",
    "            'frequency':  s3,\n",
    "            'srm_noise':  s4,\n",
    "            'gram_style': s5,\n",
    "            'attn_weights': attn_weights,\n",
    "        }\n",
    "        return fused, stream_feats\n",
    "\n",
    "    def forward_image(self, x):\n",
    "        \"\"\"Image path. x: (B, 3, 224, 224)\"\"\"\n",
    "        fused, stream_feats = self.extract_image_features(x)\n",
    "        h = self.image_head(fused)\n",
    "        return {\n",
    "            'fake_logit':  self.image_binary_out(h),   # (B, 1)\n",
    "            'type_logits': self.image_type_out(h),     # (B, N_TYPES)\n",
    "            'stream_feats': stream_feats,\n",
    "        }\n",
    "\n",
    "    def forward_video(self, x):\n",
    "        \"\"\"\n",
    "        Video path.\n",
    "        x: (B, T, 3, 224, 224)\n",
    "        \"\"\"\n",
    "        B, T, C, H, W = x.shape\n",
    "\n",
    "        # Run penta-stream on each frame\n",
    "        # Reshape to (B*T, 3, H, W) for batch processing\n",
    "        x_flat = x.view(B * T, C, H, W)\n",
    "        fused_frames, stream_feats = self.extract_image_features(x_flat)\n",
    "        # fused_frames: (B*T, 1280)\n",
    "\n",
    "        # CLIP features per frame for temporal stream\n",
    "        clip_feats = stream_feats['clip'].view(B, T, -1)   # (B, T, 512)\n",
    "\n",
    "        # Temporal transformer\n",
    "        temporal_feat = self.temporal(clip_feats)  # (B, 512)\n",
    "\n",
    "        # Average penta-stream features across frames\n",
    "        fused_mean = fused_frames.view(B, T, -1).mean(dim=1)  # (B, 1280)\n",
    "\n",
    "        # Concatenate spatial + temporal\n",
    "        video_feat = torch.cat([fused_mean, temporal_feat], dim=1)  # (B, 1792)\n",
    "\n",
    "        h = self.video_head(video_feat)\n",
    "        return {\n",
    "            'fake_logit':  self.video_binary_out(h),\n",
    "            'type_logits': self.video_type_out(h),\n",
    "            'stream_feats': stream_feats,\n",
    "        }\n",
    "\n",
    "    def forward(self, x):\n",
    "        \"\"\"Auto-routes based on input dimensions.\"\"\"\n",
    "        if x.dim() == 4:\n",
    "            return self.forward_image(x)\n",
    "        elif x.dim() == 5:\n",
    "            return self.forward_video(x)\n",
    "        else:\n",
    "            raise ValueError(f'Expected 4D (image) or 5D (video) input, got {x.dim()}D')\n",
    "\n",
    "\n",
    "print('Building full model...')\n",
    "model = DeepTruthHybridV2().to(DEVICE)\n",
    "\n",
    "total  = sum(p.numel() for p in model.parameters())\n",
    "train  = sum(p.numel() for p in model.parameters() if p.requires_grad)\n",
    "print(f'Total parameters:     {total:,}')\n",
    "print(f'Trainable parameters: {train:,}')\n",
    "print(f'Frozen parameters:    {total - train:,}')"
   ]
  },
