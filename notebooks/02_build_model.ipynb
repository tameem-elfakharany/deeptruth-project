    "## Cell 11 — Loss Functions"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "\n",
    "\n",
    "class FocalLoss(nn.Module):\n",
    "    \"\"\"\n",
    "    Focal Loss — down-weights easy examples, focuses on hard ones.\n",
    "    Better than BCE for class-imbalanced deepfake detection.\n",
    "    gamma=2 is the standard setting from the original paper.\n",
    "    \"\"\"\n",
    "    def __init__(self, gamma=2.0, pos_weight=None):\n",
    "        super().__init__()\n",
    "        self.gamma = gamma\n",
    "        self.pos_weight = pos_weight\n",
    "\n",
    "    def forward(self, logits, targets):\n",
    "        # logits: (B, 1), targets: (B, 1) float 0/1\n",
    "        bce = F.binary_cross_entropy_with_logits(\n",
    "            logits, targets, pos_weight=self.pos_weight, reduction='none'\n",
    "        )\n",
    "        pt = torch.exp(-bce)  # probability of correct class\n",
    "        focal = (1 - pt) ** self.gamma * bce\n",
    "        return focal.mean()\n",
    "\n",
    "\n",
    "class DeepTruthLoss(nn.Module):\n",
    "    \"\"\"\n",
    "    Combined loss:\n",
    "    total = focal_loss + 0.3 * type_ce_loss\n",
    "\n",
    "    The manipulation type auxiliary loss forces the model to learn\n",
    "    richer features — it must understand WHY something is fake.\n",
    "    \"\"\"\n",
    "    def __init__(self, type_weight=0.3, gamma=2.0):\n",
    "        super().__init__()\n",
    "        self.focal = FocalLoss(gamma=gamma)\n",
    "        self.type_ce = nn.CrossEntropyLoss(label_smoothing=0.1)\n",
    "        self.type_weight = type_weight\n",
    "\n",
    "    def forward(self, outputs, binary_labels, type_labels=None):\n",
    "        \"\"\"\n",
    "        outputs:       model output dict with 'fake_logit' and 'type_logits'\n",
    "        binary_labels: (B, 1) float — 0=real, 1=fake\n",
    "        type_labels:   (B,) long — manipulation type index (optional)\n",
    "        \"\"\"\n",
    "        fake_logit  = outputs['fake_logit']\n",
    "        type_logits = outputs['type_logits']\n",
    "\n",
    "        # Main task\n",
    "        main_loss = self.focal(fake_logit, binary_labels)\n",
    "\n",
    "        # Auxiliary task (only if type labels provided)\n",
    "        if type_labels is not None:\n",
    "            type_loss = self.type_ce(type_logits, type_labels)\n",
    "            total = main_loss + self.type_weight * type_loss\n",
    "        else:\n",
    "            type_loss = torch.tensor(0.0)\n",
    "            total = main_loss\n",
    "\n",
    "        return total, {'main': main_loss.item(), 'type': type_loss.item()}\n",
    "\n",
    "\n",
    "# Test loss\n",
    "criterion = DeepTruthLoss()\n",
    "dummy_out = {'fake_logit': torch.randn(4, 1), 'type_logits': torch.randn(4, N_TYPES)}\n",
    "dummy_binary = torch.randint(0, 2, (4, 1)).float()\n",
    "dummy_types  = torch.randint(0, N_TYPES, (4,))\n",
    "\n",
    "loss, components = criterion(dummy_out, dummy_binary, dummy_types)\n",
    "print(f'Total loss: {loss.item():.4f}')\n",
    "print(f'Components: {components}')"
   ]
