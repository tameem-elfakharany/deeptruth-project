   "source": [
    "## Cell 8 — Temporal Stream (Video Path)\n",
    "\n",
    "For video, the penta-stream backbone runs on each of 32 frames.\n",
    "The temporal transformer then attends across the frame sequence,\n",
    "detecting motion inconsistencies and temporal artifacts."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import torch\n",
    "import torch.nn as nn\n",
    "import math\n",
    "\n",
    "\n",
    "class TemporalTransformer(nn.Module):\n",
    "    \"\"\"\n",
    "    Temporal stream for video: attends across frame embeddings.\n",
    "    Input:  (B, T, D) — T frame embeddings from penta-stream\n",
    "    Output: (B, out_dim)\n",
    "    \"\"\"\n",
    "    def __init__(self, in_dim=512, n_frames=32, n_heads=8, n_layers=4, out_dim=512):\n",
    "        super().__init__()\n",
    "        self.in_dim = in_dim\n",
    "        self.n_frames = n_frames\n",
    "\n",
    "        # Learnable positional embedding (temporal position = which frame)\n",
    "        self.pos_embed = nn.Parameter(torch.randn(1, n_frames, in_dim) * 0.02)\n",
    "\n",
    "        # Transformer encoder\n",
    "        encoder_layer = nn.TransformerEncoderLayer(\n",
    "            d_model=in_dim,\n",
    "            nhead=n_heads,\n",
    "            dim_feedforward=in_dim * 4,\n",
    "            dropout=0.1,\n",
    "            activation='gelu',\n",
    "            batch_first=True,\n",
    "            norm_first=True,  # pre-norm (more stable)\n",
    "        )\n",
    "        self.transformer = nn.TransformerEncoder(encoder_layer, num_layers=n_layers)\n",
    "\n",
    "        # CLS token aggregation\n",
    "        self.cls_token = nn.Parameter(torch.randn(1, 1, in_dim) * 0.02)\n",\n",
    "\n",
    "        self.proj = nn.Sequential(\n",
    "            nn.Linear(in_dim, out_dim),\n",
    "            nn.LayerNorm(out_dim),\n",
    "            nn.GELU(),\n",
    "        )\n",
    "\n",
    "    def forward(self, frame_embeds):\n",
    "        # frame_embeds: (B, T, D)\n",
    "        B, T, D = frame_embeds.shape\n",
    "\n",
    "        # Add positional embedding\n",
    "        x = frame_embeds + self.pos_embed[:, :T, :]\n",
    "\n",
    "        # Prepend CLS token\n",
    "        cls = self.cls_token.expand(B, -1, -1)  # (B, 1, D)\n",
    "        x = torch.cat([cls, x], dim=1)           # (B, T+1, D)\n",
    "\n",
    "        # Run through transformer\n",
    "        out = self.transformer(x)  # (B, T+1, D)\n",
    "\n",
    "        # Use CLS token output as the temporal summary\n",
    "        return self.proj(out[:, 0, :])  # (B, out_dim)\n",
    "\n",
    "\n",
    "temporal = TemporalTransformer(in_dim=512, n_frames=32).to(DEVICE)\n",
    "frame_embeds = torch.randn(2, 32, 512).to(DEVICE)  # 2 videos, 32 frames, 512-dim each\n",
    "out = temporal(frame_embeds)\n",
    "print(f'Temporal stream output shape: {out.shape}')  # (2, 512)"
   ]
  },
