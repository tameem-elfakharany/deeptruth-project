   "source": [
    "# Cell 8 — Final summary\n",
    "\n",
    "print('=' * 60)\n",
    "print('DeepTruth ONNX Export Complete')\n",
    "print('=' * 60)\n",
    "print()\n",
    "print('Files saved to Drive/DeepTruth/onnx_models/:')\n",
    "for f in sorted(os.listdir(ONNX_DIR)):\n",
    "    fpath = os.path.join(ONNX_DIR, f)\n",
    "    size = os.path.getsize(fpath) / 1e6\n",
    "    print(f'  {f:<40} {size:6.1f} MB')\n",
    "\n",
    "print()\n",
    "print('Next steps:')\n",
    "print('1. Download the onnx_models/ folder from Drive')\n",
    "print('2. Place in DeepTruth/models/ on your local machine')\n",
    "print('3. Update the backend (FastAPI) to use onnxruntime instead of TensorFlow')\n",
    "print('4. Test the full pipeline with a test image/video')\n",
    "print()\n",
    "print(f'Image model inference: ~{ort_time:.0f} ms/image (CPU)')\n",
    "print(f'Temperature calibration: T = {T_IMAGE:.4f}')"
   ]
  }
