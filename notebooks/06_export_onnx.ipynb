 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# DeepTruth — Stage 7: ONNX Export & Validation\n",
    "\n",
    "**Run on Google Colab (any GPU)**\n",
    "\n",
    "### What this notebook does\n",
    "1. Exports both image and video models to ONNX format\n",
    "2. Validates ONNX outputs match PyTorch outputs\n",
    "3. Benchmarks inference speed\n",
    "4. Saves ONNX models to Drive for backend deployment\n",
    "\n",
    "### Prerequisites\n",
    "- Complete notebooks 02–05\n",
    "- `deeptruth_image_hardened_final.pth` and `deeptruth_video_model_final.pth` in Drive/checkpoints"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 1 — Setup\n",
    "from google.colab import drive\n",
    "drive.mount('/content/drive')\n",
    "\n",
    "!pip install -q timm open-clip-torch einops onnx onnxruntime onnxsim\n",
    "\n",
    "import os, json, time\n",
    "import numpy as np\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import onnx\n",
    "import onnxruntime as ort\n",
    "from onnxsim import simplify\n",
    "\n",
    "DEVICE = 'cuda' if torch.cuda.is_available() else 'cpu'\n",
    "DRIVE_ROOT = '/content/drive/MyDrive/DeepTruth'\n",
    "CKPT_DIR   = f'{DRIVE_ROOT}/checkpoints'\n",
    "ONNX_DIR   = f'{DRIVE_ROOT}/onnx_models'\n",
    "os.makedirs(ONNX_DIR, exist_ok=True)\n",
    "\n",
    "print(f'Device: {DEVICE}')\n",
    "print(f'ONNX Runtime version: {ort.__version__}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 2 — Load image model\n",
    "# (Run cells 2-9 of 02_build_model.ipynb first to define DeepTruthHybridV2)\n",
    "\n",
    "FAKE_TYPE_MAP = {\n",
    "    'real': 0, 'Deepfakes': 1, 'Face2Face': 2, 'FaceSwap': 3,\n",
    "    'NeuralTextures': 4, 'DeepFakeDetection': 5, 'FaceShifter': 6,\n",
    "    'gan_generated': 7, 'diffusion_generated': 8, 'unknown_fake': 9,\n",
    "}\n",
    "\n",
    "IMAGE_CKPT = f'{CKPT_DIR}/deeptruth_image_hardened_final.pth'\n",
    "if not os.path.exists(IMAGE_CKPT):\n",
    "    IMAGE_CKPT = f'{CKPT_DIR}/deeptruth_image_model_final.pth'  # fallback\n",
    "\n",
    "img_model = DeepTruthHybridV2(num_fake_types=len(FAKE_TYPE_MAP), dropout=0.0).to(DEVICE)\n",
    "img_ckpt  = torch.load(IMAGE_CKPT, map_location=DEVICE)\n",
    "img_model.load_state_dict(img_ckpt['model_state'], strict=False)\n",
    "img_model.eval()\n",
    "\n",
    "T_IMAGE = img_ckpt.get('temperature', 1.0)\n",
    "print(f'Image model loaded from {IMAGE_CKPT}')\n",
    "print(f'Temperature: {T_IMAGE:.4f}')\n",
    "\n",
    "# Sanity check\n",
    "dummy_img = torch.randn(1, 3, 224, 224).to(DEVICE)\n",
    "with torch.no_grad():\n",
    "    out = img_model(dummy_img)\n",
    "print(f'Image forward pass: binary_logit={out[\"binary_logit\"].shape}, type_logit={out[\"type_logit\"].shape}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 3 — Wrapper model with temperature scaling and softmax output\n",
    "# ONNX consumers (FastAPI backend) expect a single probability output\n",
    "\n",
    "class ImageModelWrapper(nn.Module):\n",
    "    \"\"\"Wraps DeepTruthHybridV2 for ONNX export.\n",
    "    Input:  (B, 3, 224, 224) — normalized image tensor\n",
    "    Output: (B, 2) — [P(real), P(fake)] probabilities\n",
    "    \"\"\"\n",
    "    def __init__(self, model, temperature=1.0):\n",
    "        super().__init__()\n",
    "        self.model = model\n",
    "        self.temperature = temperature\n",
    "\n",
    "    def forward(self, x):\n",
    "        out = self.model(x)\n",
    "        logits = out['binary_logit'] / self.temperature\n",
    "        return torch.softmax(logits, dim=1)  # (B, 2)\n",
    "\n",
    "\n",
    "class ImageModelFullWrapper(nn.Module):\n",
    "    \"\"\"Extended wrapper that also returns per-stream scores and fake type.\n",
    "    Outputs: probs (B,2), type_probs (B,10), stream_weights (B,5) [if available]\n",
    "    \"\"\"\n",
    "    def __init__(self, model, temperature=1.0):\n",
    "        super().__init__()\n",
    "        self.model = model\n",
    "        self.temperature = temperature\n",
    "\n",
    "    def forward(self, x):\n",
    "        out = self.model(x)\n",
    "        probs      = torch.softmax(out['binary_logit'] / self.temperature, dim=1)\n",
    "        type_probs = torch.softmax(out['type_logit'], dim=1)\n",
    "        return probs, type_probs\n",
    "\n",
    "\n",
    "img_wrapper      = ImageModelWrapper(img_model, T_IMAGE).to(DEVICE).eval()\n",
    "img_full_wrapper = ImageModelFullWrapper(img_model, T_IMAGE).to(DEVICE).eval()\n",
    "\n",
    "# Test\n",
    "with torch.no_grad():\n",
    "    simple_out = img_wrapper(dummy_img)\n",
    "    full_out   = img_full_wrapper(dummy_img)\n",
    "print(f'Simple wrapper output: {simple_out.shape} — values: {simple_out[0].tolist()}')\n",
    "print(f'Full wrapper: probs={full_out[0].shape}, type_probs={full_out[1].shape}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 4 — Export image model to ONNX\n",
    "\n",
    "ONNX_IMAGE_PATH      = f'{ONNX_DIR}/deeptruth_image.onnx'\n",
    "ONNX_IMAGE_SIM_PATH  = f'{ONNX_DIR}/deeptruth_image_sim.onnx'\n",
    "ONNX_IMAGE_FULL_PATH = f'{ONNX_DIR}/deeptruth_image_full.onnx'\n",
    "\n",
    "dummy_img_cpu = dummy_img.cpu()\n",
    "\n",
    "# Export simple (probs only)\n",
    "print('Exporting simple image model...')\n",
    "torch.onnx.export(\n",
    "    img_wrapper.cpu(),\n",
    "    dummy_img_cpu,\n",
    "    ONNX_IMAGE_PATH,\n",
    "    export_params=True,\n",
    "    opset_version=17,\n",
    "    do_constant_folding=True,\n",
    "    input_names=['image'],\n",
    "    output_names=['probabilities'],\n",
    "    dynamic_axes={\n",
    "        'image':         {0: 'batch_size'},\n",
    "        'probabilities': {0: 'batch_size'},\n",
    "    },\n",
    ")\n",
    "img_wrapper.to(DEVICE)\n",
    "\n",
    "# Export full (probs + type)\n",
    "print('Exporting full image model...')\n",
    "torch.onnx.export(\n",
    "    img_full_wrapper.cpu(),\n",
    "    dummy_img_cpu,\n",
    "    ONNX_IMAGE_FULL_PATH,\n",
    "    export_params=True,\n",
    "    opset_version=17,\n",
    "    do_constant_folding=True,\n",
    "    input_names=['image'],\n",
    "    output_names=['probabilities', 'type_probabilities'],\n",
    "    dynamic_axes={\n",
    "        'image':              {0: 'batch_size'},\n",
    "        'probabilities':      {0: 'batch_size'},\n",
    "        'type_probabilities': {0: 'batch_size'},\n",
    "    },\n",
    ")\n",
    "img_full_wrapper.to(DEVICE)\n",
    "\n",
    "# Verify ONNX model\n",
    "onnx_model = onnx.load(ONNX_IMAGE_PATH)\n",
    "onnx.checker.check_model(onnx_model)\n",
    "print(f'ONNX model verified: {ONNX_IMAGE_PATH}')\n",
    "print(f'Size: {os.path.getsize(ONNX_IMAGE_PATH)/1e6:.1f} MB')\n",
    "\n",
    "# Simplify (remove redundant ops)\n",
    "print('Simplifying ONNX model...')\n",
    "model_simplified, check = simplify(onnx_model)\n",
    "assert check, 'Simplified ONNX model failed verification'\n",
    "onnx.save(model_simplified, ONNX_IMAGE_SIM_PATH)\n",
    "print(f'Simplified: {os.path.getsize(ONNX_IMAGE_SIM_PATH)/1e6:.1f} MB')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 5 — Validate ONNX image model\n",
    "\n",
    "sess_options = ort.SessionOptions()\n",
    "sess_options.graph_optimization_level = ort.GraphOptimizationLevel.ORT_ENABLE_ALL\n",
    "\n",
    "ort_session = ort.InferenceSession(\n",
    "    ONNX_IMAGE_SIM_PATH,\n",
    "    sess_options=sess_options,\n",
    "    providers=['CPUExecutionProvider'],\n",
    ")\n",
    "\n",
    "# Compare PyTorch vs ONNX outputs\n",
    "test_inputs = torch.randn(4, 3, 224, 224)\n",
    "with torch.no_grad():\n",
    "    pt_out = img_wrapper(test_inputs.to(DEVICE)).cpu().numpy()\n",
    "\n",
    "ort_inputs = {'image': test_inputs.numpy()}\n",
    "ort_out = ort_session.run(None, ort_inputs)[0]\n",
    "\n",
    "max_diff = np.abs(pt_out - ort_out).max()\n",
    "print(f'Max absolute difference (PyTorch vs ONNX): {max_diff:.6f}')\n",
    "assert max_diff < 1e-3, f'ONNX outputs diverge too much: {max_diff}'\n",
    "print('ONNX validation PASSED')\n",
    "\n",
    "# Benchmark\n",
    "N_RUNS = 50\n",
    "test_np = np.random.randn(1, 3, 224, 224).astype(np.float32)\n",
    "start = time.time()\n",
    "for _ in range(N_RUNS):\n",
    "    ort_session.run(None, {'image': test_np})\n",
    "ort_time = (time.time() - start) / N_RUNS * 1000\n",
    "print(f'ONNX inference: {ort_time:.1f} ms/image (CPU)')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 6 — Export video model to ONNX\n",
    "\n",
    "VIDEO_CKPT = f'{CKPT_DIR}/deeptruth_video_model_final.pth'\n",
    "\n",
    "if not os.path.exists(VIDEO_CKPT):\n",
    "    print('Video model not found. Skipping video ONNX export.')\n",
    "    print('Run notebook 04 first.')\n",
    "else:\n",
    "    vid_model = DeepTruthHybridV2(num_fake_types=len(FAKE_TYPE_MAP), dropout=0.0).to(DEVICE)\n",
    "    vid_ckpt  = torch.load(VIDEO_CKPT, map_location=DEVICE)\n",
    "    vid_model.load_state_dict(vid_ckpt['model_state'], strict=False)\n",
    "    vid_model.eval()\n",
    "\n",
    "    T_VIDEO = vid_ckpt.get('temperature', 1.0)\n",
    "    N_FRAMES = vid_ckpt.get('n_frames', 32)\n",
    "\n",
    "    class VideoModelWrapper(nn.Module):\n",
    "        \"\"\"Wraps DeepTruthHybridV2 video path for ONNX.\n",
    "        Input:  (B, T, 3, 224, 224)\n",
    "        Output: (B, 2) probs, (B, 10) type_probs\n",
    "        \"\"\"\n",
    "        def __init__(self, model, temperature=1.0):\n",
    "            super().__init__()\n",
    "            self.model = model\n",
    "            self.temperature = temperature\n",
    "\n",
    "        def forward(self, x):\n",
    "            # x: (B, T, 3, H, W)\n",
    "            out = self.model(x)\n",
    "            probs      = torch.softmax(out['binary_logit'] / self.temperature, dim=1)\n",
    "            type_probs = torch.softmax(out['type_logit'], dim=1)\n",
    "            return probs, type_probs\n",
    "\n",
    "    vid_wrapper = VideoModelWrapper(vid_model, T_VIDEO).cpu().eval()\n",
    "\n",
    "    ONNX_VIDEO_PATH = f'{ONNX_DIR}/deeptruth_video.onnx'\n",
    "    dummy_vid = torch.randn(1, N_FRAMES, 3, 224, 224)\n",
    "\n",
    "    print(f'Exporting video model (input: {dummy_vid.shape})...')\n",
    "    torch.onnx.export(\n",
    "        vid_wrapper,\n",
    "        dummy_vid,\n",
    "        ONNX_VIDEO_PATH,\n",
    "        export_params=True,\n",
    "        opset_version=17,\n",
    "        do_constant_folding=True,\n",
    "        input_names=['video'],\n",
    "        output_names=['probabilities', 'type_probabilities'],\n",
    "        dynamic_axes={\n",
    "            'video':              {0: 'batch_size'},\n",
    "            'probabilities':      {0: 'batch_size'},\n",
    "            'type_probabilities': {0: 'batch_size'},\n",
    "        },\n",
    "    )\n",
    "\n",
    "    onnx_vid = onnx.load(ONNX_VIDEO_PATH)\n",
    "    onnx.checker.check_model(onnx_vid)\n",
    "    size_mb = os.path.getsize(ONNX_VIDEO_PATH) / 1e6\n",
    "    print(f'Video ONNX saved: {ONNX_VIDEO_PATH} ({size_mb:.1f} MB)')\n",
    "\n",
    "    vid_wrapper.to(DEVICE)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 7 — Save deployment metadata\n",
    "# This JSON is read by the FastAPI backend to configure inference\n",
    "\n",
    "FAKE_TYPE_NAMES = {\n",
    "    0: 'real',\n",
    "    1: 'Deepfakes (face swap)',\n",
    "    2: 'Face2Face (reenactment)',\n",
    "    3: 'FaceSwap',\n",
    "    4: 'NeuralTextures',\n",
    "    5: 'DeepFakeDetection',\n",
    "    6: 'FaceShifter',\n",
    "    7: 'GAN-generated',\n",
    "    8: 'Diffusion-generated',\n",
    "    9: 'Unknown fake',\n",
    "}\n",
    "\n",
    "deployment_meta = {\n",
    "    'image_model': {\n",
    "        'onnx_path': 'deeptruth_image_sim.onnx',\n",
    "        'onnx_full_path': 'deeptruth_image_full.onnx',\n",
    "        'temperature': T_IMAGE,\n",
    "        'input_shape': [1, 3, 224, 224],\n",
    "        'imagenet_mean': [0.485, 0.456, 0.406],\n",
    "        'imagenet_std':  [0.229, 0.224, 0.225],\n",
    "        'output_names': ['probabilities', 'type_probabilities'],\n",
    "    },\n",
    "    'video_model': {\n",
    "        'onnx_path': 'deeptruth_video.onnx',\n",
    "        'temperature': 1.0,\n",
    "        'n_frames': 32,\n",
    "        'input_shape': [1, 32, 3, 224, 224],\n",
    "        'imagenet_mean': [0.485, 0.456, 0.406],\n",
    "        'imagenet_std':  [0.229, 0.224, 0.225],\n",
    "        'output_names': ['probabilities', 'type_probabilities'],\n",
    "    },\n",
    "    'fake_type_names': FAKE_TYPE_NAMES,\n",
    "    'fake_type_map': FAKE_TYPE_MAP,\n",
    "}\n",
    "\n",
    "meta_path = f'{ONNX_DIR}/deployment_meta.json'\n",
    "with open(meta_path, 'w') as f:\n",
    "    json.dump(deployment_meta, f, indent=2)\n",
    "\n",
    "print(f'Deployment metadata saved: {meta_path}')\n",
    "print(json.dumps(deployment_meta, indent=2))"
   ]
  },
  {
   "cell_type": "code",
